{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "SuperSecretKeyForQuickBiteAuthService_DoNotUseInProduction_MustBeLongEnough",
    "Issuer": "QuickBite.Auth",
    "Audience": "QuickBite.Users"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "restaurant-route": {
        "ClusterId": "restaurant-cluster",
        "Match": { "Path": "/api/v1/restaurants/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "menu-route": {
        "ClusterId": "menu-cluster",
        "Match": { "Path": "/api/v1/menu/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/v1/cart/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/v1/orders/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/v1/payments/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "wallet-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/v1/wallet/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "delivery-route": {
        "ClusterId": "delivery-cluster",
        "Match": { "Path": "/api/v1/agents/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/v1/notifications/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1" } ]
      },
      "signalr-delivery-hub": {
        "ClusterId": "delivery-cluster",
        "Match": { "Path": "/hubs/delivery-location/{**catch-all}" }
      },
      "signalr-notification-hub": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5001/" } }
      },
      "restaurant-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5002/" } }
      },
      "menu-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5003/" } }
      },
      "cart-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5004/" } }
      },
      "order-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5005/" } }
      },
      "payment-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5006/" } }
      },
      "delivery-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5007/" } }
      },
      "notification-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5009/" } }
      }
    }
  }
}
